#!/usr/bin/env bash
# addpath - add directories to PATH persistently across shells
#
# SOURCE this file in your .zshrc / .bashrc / .profile / etc:
#   source /path/to/addpath
#
# Usage:
#   addpath [-p|--prepend] <dir> [dir...]
#
# Paths are stored in ${XDG_CONFIG_HOME:-~/.config}/addpath/paths
# and loaded into PATH each time this file is sourced.

# Guard: refuse to run as a plain script (can't modify parent shell's PATH)
_addpath_is_sourced() {
    if [ -n "$BASH_VERSION" ]; then
        [[ "${BASH_SOURCE[0]}" != "${0}" ]]
    elif [ -n "$ZSH_VERSION" ]; then
        [[ "$ZSH_EVAL_CONTEXT" == *:file* ]]
    else
        return 0  # assume sourced in other POSIX shells
    fi
}

if ! _addpath_is_sourced; then
    echo "addpath: must be sourced, not executed" >&2
    echo "Add to your .zshrc or .bashrc:" >&2
    echo "  source ${BASH_SOURCE[0]:-$0}" >&2
    exit 1
fi
unset -f _addpath_is_sourced

_ADDPATH_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/addpath/paths"

# Load all stored paths into the current shell's PATH
_addpath_load() {
    [ -f "$_ADDPATH_FILE" ] || return
    local line marker dir prepends="" appends=""
    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        marker="${line%%:*}"
        dir="${line#*:}"
        case ":$PATH:" in
            *":$dir:"*) continue ;;
        esac
        if [ "$marker" = "p" ]; then
            prepends="$dir${prepends:+:$prepends}"
        else
            appends="${appends:+$appends:}$dir"
        fi
    done < "$_ADDPATH_FILE"
    [ -n "$prepends" ] && PATH="$prepends:$PATH"
    [ -n "$appends" ] && PATH="$PATH:$appends"
    export PATH
}

addpath() {
    local prepend=0 dir marker
    local -a dirs=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--prepend) prepend=1; shift ;;
            --) shift; dirs+=("$@"); break ;;
            -h|--help)
                echo "Usage: addpath [-p|--prepend] <dir> [dir...]"
                echo "  -p, --prepend   prepend to PATH instead of appending"
                return 0
                ;;
            -*) echo "addpath: unknown option: $1" >&2; return 1 ;;
            *) dirs+=("$1"); shift ;;
        esac
    done

    if [[ ${#dirs[@]} -eq 0 ]]; then
        echo "Usage: addpath [-p|--prepend] <dir> [dir...]" >&2
        return 1
    fi

    mkdir -p "${_ADDPATH_FILE%/*}"

    for dir in "${dirs[@]}"; do
        dir="${dir%/}"

        if grep -qxF "a:$dir" "$_ADDPATH_FILE" 2>/dev/null || \
           grep -qxF "p:$dir" "$_ADDPATH_FILE" 2>/dev/null; then
            echo "addpath: already stored: $dir" >&2
            continue
        fi

        if [[ $prepend -eq 1 ]]; then marker=p; else marker=a; fi
        echo "$marker:$dir" >> "$_ADDPATH_FILE"

        case ":$PATH:" in
            *":$dir:"*) ;;
            *)
                if [[ $prepend -eq 1 ]]; then
                    PATH="$dir:$PATH"
                else
                    PATH="$PATH:$dir"
                fi
                export PATH
                ;;
        esac

        echo "addpath: added $dir"
    done
}

_addpath_load
