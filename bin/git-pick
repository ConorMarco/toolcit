#!/usr/bin/env bash
# git-pick - cherry-pick the last n commits to main
#
# Usage: git pick [<n>]
# Defaults to 1.

set -euo pipefail

n="${1:-1}"

if ! [[ "$n" =~ ^[1-9][0-9]*$ ]]; then
    echo "Usage: git pick [<n>]" >&2
    exit 1
fi

commits="$(git log --reverse --format="%H" -n "$n" HEAD)"

git checkout main
git cherry-pick $commits
